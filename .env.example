DJANGO_ENV=production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=change-me-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=tu-dominio.com,www.tu-dominio.com
DJANGO_TIME_ZONE=America/Tegucigalpa

DJANGO_DB_ENGINE=sqlite
SQLITE_NAME=

# Si usaras SQL Server en produccion, cambia DJANGO_DB_ENGINE=sqlserver y completa:
# SQLSERVER_NAME=NombreBase
# SQLSERVER_HOST=servidor\\instancia
# SQLSERVER_PORT=
# SQLSERVER_USER=
# SQLSERVER_PASSWORD=
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

DJANGO_USE_PROXY_SSL_HEADER=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

# Bootstrap de acceso inicial
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@tu-dominio.com
SUPERADMIN_PASSWORD=change-me-now
